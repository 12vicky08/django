{
  "name": "todo-desktop",
  "version": "1.0.0",
  "description": "A premium desktop to-do application",
  "main": "main.js",
  "author": "12vicky08",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/12vicky08/django.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.todo.desktop",
    "productName": "Todo Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "icon.png"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "icon.png"
    }
  }
}
